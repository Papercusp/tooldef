{
  "name": "@papercusp/tooldef",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "Function-as-truth tool framework: write one typed (input, ctx) => result function and project it onto HTTP, MCP, IPC, and in-process transports with uniform auth/role/quota/telemetry/streaming. Schema-agnostic (Standard Schema), host-agnostic (all I/O injected).",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./delta-client": {
      "types": "./src/delta-client.ts",
      "import": "./src/delta-client.ts",
      "default": "./src/delta-client.ts"
    },
    "./state-delta": {
      "types": "./src/state-delta.ts",
      "import": "./src/state-delta.ts",
      "default": "./src/state-delta.ts"
    }
  },
  "dependencies": {
    "@papercusp/chat-protocol": "*",
    "@papercusp/result-encoding": "*",
    "@papercusp/rules": "*",
    "@standard-schema/spec": "^1.0.0",
    "typescript": "~6.0.0"
  },
  "scripts": {
    "test": "vitest",
    "build": "tsc -p tsconfig.build.json"
  }
}
